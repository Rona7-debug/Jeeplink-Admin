<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F4">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Reply to Feedback"
            android:fontFamily="@font/lato_bold"
            android:textColor="#0F172A"
            android:textSize="20sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Original Feedback Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORIGINAL FEEDBACK"
                android:fontFamily="@font/lato_bold"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E8E8E8"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- User row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cvAvatar"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            app:cardCornerRadius="19dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#E8EAF6">
                            <TextView
                                android:id="@+id/tvAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="?"
                                android:gravity="center"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#1246C2"
                                android:textSize="16sp" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">
                            <TextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="User"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#0F172A"
                                android:textSize="15sp" />
                            <TextView
                                android:id="@+id/tvTimeAgo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Just now"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#94A3B8"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEW"
                            android:fontFamily="@font/lato_bold"
                            android:textColor="#1246C2"
                            android:textSize="11sp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:background="@drawable/badge_new" />

                    </LinearLayout>

                    <!-- Stars -->
                    <TextView
                        android:id="@+id/tvStars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★★★★★"
                        android:textColor="#FBBC05"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp" />

                    <!-- Categories -->
                    <TextView
                        android:id="@+id/tvCategories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"
                        android:visibility="gone" />

                    <!-- Feedback text -->
                    <TextView
                        android:id="@+id/tvFeedbackText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:fontFamily="@font/lato_bold"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/qaThankYou"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Thanks for reporting"
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#1246C2"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/chip_outline_blue" />

                    <TextView
                        android:id="@+id/qaIssueFixed"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Issue Fixed"
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#1246C2"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/chip_outline_blue" />

                    <TextView
                        android:id="@+id/qaNeedMoreInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Need more info"
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#1246C2"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/chip_outline_blue" />

                    <TextView
                        android:id="@+id/qaUnderReview"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Under Review"
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#1246C2"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/chip_outline_blue" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Your Response -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Response"
                android:fontFamily="@font/lato_bold"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#E2E5EA"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <EditText
                        android:id="@+id/etReply"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="@null"
                        android:hint="Type your reply here..."
                        android:textColor="#0F172A"
                        android:textColorHint="#9EA1A8"
                        android:fontFamily="@font/lato_regular"
                        android:textSize="14sp"
                        android:inputType="textMultiLine"
                        android:gravity="top|start"
                        android:lineSpacingMultiplier="1.5" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F1F3"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tvCharCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="6dp"
                        android:text="0 / 500"
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#9EA1A8"
                        android:textSize="11sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mark as resolved toggle -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E8E8E8"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_active_routes_blue"
                        app:tint="#16A34A"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mark as Resolved"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchResolved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8E8E8"
            app:cardBackgroundColor="#FFFFFF">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Cancel"
                android:gravity="center"
                android:fontFamily="@font/lato_bold"
                android:textColor="#64748B"
                android:textSize="15sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnSendReply"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1246C2">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Send Reply"
                android:gravity="center"
                android:fontFamily="@font/lato_bold"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>