<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E8E8E8"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="38dp"
                android:layout_height="38dp"
                app:cardCornerRadius="19dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1246C2">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="R"
                    android:gravity="center"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#0F172A"
                    android:textSize="15sp" />
                <TextView
                    android:id="@+id/tvTimeAgo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Just now"
                    android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW"
                android:fontFamily="@font/lato_bold"
                android:textColor="#C2410C"
                android:textSize="11sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/badge_new" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★★★★★"
            android:textColor="#FBBC05"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:fontFamily="@font/lato_regular"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvFeedbackText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:fontFamily="@font/lato_regular"
            android:textColor="#0F172A"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAdminReply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin: Thanks for your feedback!"
            android:fontFamily="@font/lato_regular"
            android:textColor="#1E3A8A"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="12dp"
            android:padding="12dp"
            android:background="@drawable/bg_admin_reply"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvReplyBtn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Reply"
                android:fontFamily="@font/lato_bold"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/btn_blue_rounded" />

            <TextView
                android:id="@+id/tvViewMoreBtn"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="View More"
                android:fontFamily="@font/lato_bold"
                android:textColor="#1246C2"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/btn_outline_blue" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>