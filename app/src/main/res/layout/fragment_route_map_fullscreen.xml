<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/mapViewFullscreen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/topOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:background="#CCF8F8F8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#000000" />

        <TextView
            android:id="@+id/tvMapTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Route Map"
            android:fontFamily="@font/lato_bold"
            android:textColor="#000000"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvWaypointCountFullscreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 pts"
            android:fontFamily="@font/lato_regular"
            android:textColor="#64748B"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#CCF8F8F8"
        app:layout_constraintTop_toBottomOf="@id/topOverlay"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <EditText
                    android:id="@+id/etMapSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:hint="Search location..."
                    android:textColorHint="#AAAAAA"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:inputType="text" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/btnMapSearch"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Search"
                android:fontFamily="@font/lato_bold"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/btn_blue_rounded" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/suggestionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#000000">

            <ListView
                android:id="@+id/lvSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="200dp"
                android:scrollbars="vertical" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:background="#CCF8F8F8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnUndoWaypoint"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Undo Last"
            android:fontFamily="@font/lato_bold"
            android:textColor="#1246C2"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/btn_outline_blue" />

        <TextView
            android:id="@+id/btnClearWaypoints"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Clear All"
            android:fontFamily="@font/lato_bold"
            android:textColor="#E03C3C"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/btn_outline_blue" />

        <TextView
            android:id="@+id/btnDoneFullscreen"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Done"
            android:fontFamily="@font/lato_bold"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:background="@drawable/btn_blue_rounded" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>