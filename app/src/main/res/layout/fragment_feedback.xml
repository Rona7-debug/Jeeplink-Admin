<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F4"
    tools:context=".Home.Feedback">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingTop="52dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Routes Feedback"
                android:fontFamily="@font/lato_bold"
                android:textColor="#0F172A"
                android:textSize="22sp" />

            <ImageView
                android:id="@+id/btnSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#64748B" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/searchBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E5EA"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_search"
                        app:tint="#94A3B8"
                        android:layout_marginEnd="8dp" />

                    <EditText
                        android:id="@+id/etFeedbackSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Search feedback or category..."
                        android:textColorHint="#94A3B8"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:fontFamily="@font/lato_regular"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"
                        android:inputType="text" />

                    <ImageView
                        android:id="@+id/btnClearSearch"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:src="@drawable/ic_close"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/tabRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tabAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:fontFamily="@font/lato_bold"
                android:textColor="#1246C2"
                android:textSize="15sp"
                android:paddingStart="4dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tabNew"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New"
                android:fontFamily="@font/lato_regular"
                android:textColor="#64748B"
                android:textSize="15sp"
                android:paddingStart="4dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tabResolved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resolved"
                android:fontFamily="@font/lato_regular"
                android:textColor="#64748B"
                android:textSize="15sp"
                android:paddingStart="4dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tabPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:fontFamily="@font/lato_regular"
                android:textColor="#64748B"
                android:textSize="15sp"
                android:paddingStart="4dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tabArchive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Archive"
                android:fontFamily="@font/lato_regular"
                android:textColor="#64748B"
                android:textSize="15sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:id="@+id/tabDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E8E8E8"
        app:layout_constraintTop_toBottomOf="@id/tabRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="110dp"
        app:layout_constraintTop_toBottomOf="@id/tabDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/chipDateFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/chip_outline_blue"
                    android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Last 7 days" android:fontFamily="@font/lato_regular" android:textColor="#1246C2" android:textSize="13sp" />
                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:layout_marginStart="4dp" android:src="@drawable/ic_arrow_drop_down" app:tint="#1246C2" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipRatingFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/chip_outline_blue">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Any Rating"
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#1246C2"
                        android:textSize="13sp" />

                    <ImageView android:layout_width="14dp" android:layout_height="14dp" android:layout_marginStart="4dp" android:src="@drawable/ic_arrow_drop_down" app:tint="#1246C2" />
                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E8E8E8"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:id="@+id/tvAvgRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#0F172A"
                                android:textSize="44sp" />

                            <TextView
                                android:id="@+id/tvTotalReviews"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loading..."
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#94A3B8"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="5" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                                <ProgressBar android:id="@+id/progressBar5" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" android:progress="0" android:progressTint="#1246C2" android:progressBackgroundTint="#E8E8E8" />
                                <TextView android:id="@+id/tvPct5" android:layout_width="30dp" android:layout_height="wrap_content" android:text="0%" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="4" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                                <ProgressBar android:id="@+id/progressBar4" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" android:progress="0" android:progressTint="#1246C2" android:progressBackgroundTint="#E8E8E8" />
                                <TextView android:id="@+id/tvPct4" android:layout_width="30dp" android:layout_height="wrap_content" android:text="0%" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="3" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                                <ProgressBar android:id="@+id/progressBar3" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" android:progress="0" android:progressTint="#1246C2" android:progressBackgroundTint="#E8E8E8" />
                                <TextView android:id="@+id/tvPct3" android:layout_width="30dp" android:layout_height="wrap_content" android:text="0%" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="2" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                                <ProgressBar android:id="@+id/progressBar2" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" android:progress="0" android:progressTint="#1246C2" android:progressBackgroundTint="#E8E8E8" />
                                <TextView android:id="@+id/tvPct2" android:layout_width="30dp" android:layout_height="wrap_content" android:text="0%" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="1" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                                <ProgressBar android:id="@+id/progressBar1" style="@style/Widget.AppCompat.ProgressBar.Horizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" android:progress="0" android:progressTint="#1246C2" android:progressBackgroundTint="#E8E8E8" />
                                <TextView android:id="@+id/tvPct1" android:layout_width="30dp" android:layout_height="wrap_content" android:text="0%" android:fontFamily="@font/lato_regular" android:textColor="#64748B" android:textSize="12sp" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NEW"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvNew"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#C2410C"
                                android:textSize="22sp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E8E8E8" android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PENDING"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvPending"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#1246C2"
                                android:textSize="22sp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E8E8E8" android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RESOLVED"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvResolved"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#16A34A"
                                android:textSize="22sp" />
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="40dp" android:background="#E8E8E8" android:layout_gravity="center_vertical" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ARCHIVE"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvArchived"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#E03C3C"
                                android:textSize="22sp" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Feedback"
                android:fontFamily="@font/lato_bold"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/feedbackContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/navCardView"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bottom_nav_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="20dp"
            android:layout_gravity="bottom">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <ImageView android:id="@+id/ivNavHome" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_home_blue" app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavHome" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="13sp" android:fontFamily="@font/lato_regular" android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navRoutes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">
                <ImageView android:id="@+id/ivNavRoutes" android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_routes_gray" app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavRoutes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Routes" android:textSize="13sp" android:fontFamily="@font/lato_regular" android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/navFeedback"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/ivNavFeedback"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_feedback_blue"
                    app:tint="#1246C2" />

                <TextView
                    android:id="@+id/tvNavFeedback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feedback"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#1246C2"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/ivNavSettings"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/ic_profile_blue"
                    app:tint="#94A3B8" />

                <TextView
                    android:id="@+id/tvNavSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/fabAdd"
            android:layout_width="59dp"
            android:layout_height="59dp"
            android:layout_gravity="top|center_horizontal"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1246C2">
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_add_routes" />
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>