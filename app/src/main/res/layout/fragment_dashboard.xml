<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F4"
    tools:context=".Home.Dashboard">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JeepLink Admin"
                        android:textSize="22sp"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#0F172A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Overview"
                        android:textSize="14sp"
                        android:textColor="#64748B" />

                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnNotification"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivNotifBell"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notif"
                        app:tint="#64748B" />

                    <TextView
                        android:id="@+id/tvNotifBadge"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/badge_bg"
                        android:gravity="center"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:fontFamily="@font/lato_bold"
                        android:visibility="gone" />

                </FrameLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnProfile"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#1246C2"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/tvProfileInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="A"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/lato_bold" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Row 1: Total Routes + Pending Reports -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Total Routes -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalRoutes"
                    android:layout_width="0dp"
                    android:layout_height="167dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E8E8E8"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#1A1246C2">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_total_routes_yellow"
                                app:tint="#1246C2" />

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/tvTotalRoutes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:fontFamily="@font/lato_bold"
                            android:textColor="#0F172A"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL ROUTES"
                            android:textSize="13sp"
                            android:fontFamily="@font/lato_regular"
                            android:textColor="#64748B"
                            android:letterSpacing="0.08" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Pending Reports -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPendingReports"
                    android:layout_width="0dp"
                    android:layout_height="167dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E8E8E8"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#1AFEE2E2">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_feedbaack_blue"
                                app:tint="#1246C2" />

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/tvPendingReports"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="30sp"
                            android:fontFamily="@font/lato_bold"
                            android:textColor="#0F172A"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PENDING REPORTS"
                            android:textSize="13sp"
                            android:fontFamily="@font/lato_regular"
                            android:textColor="#64748B"
                            android:letterSpacing="0.08" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Pro Subscribers Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPremium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E8E8E8"
                app:cardBackgroundColor="#1246C2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#1AFFFFFF">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield"
                            app:tint="#FCCE1A" />

                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRO ACTIVE SUBSCRIBERS"
                            android:fontFamily="@font/lato_bold"
                            android:textColor="#FCCE1A"
                            android:textSize="11sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvPremiumCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:fontFamily="@font/lato_bold"
                            android:textColor="#FFFFFF"
                            android:textSize="30sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Feedback Trends Chart -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFeedbackTrends"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E8E8E8"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Feedback Trends"
                        android:textSize="17sp"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#0F172A" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Weekly Activity"
                        android:textSize="13sp"
                        android:fontFamily="@font/lato_regular"
                        android:textColor="#64748B"
                        android:layout_marginBottom="12dp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChartFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="160dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/navCardView"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bottom_nav_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="20dp"
            android:layout_gravity="bottom">

            <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavHome" android:layout_width="20dp"
                    android:layout_height="20dp" android:src="@drawable/ic_home_blue"
                    app:tint="#1246C2" />
                <TextView android:id="@+id/tvNavHome" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Home"
                    android:textSize="13sp" android:fontFamily="@font/lato_bold"
                    android:textColor="#1246C2" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navRoutes" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavRoutes" android:layout_width="20dp"
                    android:layout_height="20dp" android:src="@drawable/ic_routes_gray"
                    app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavRoutes" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Routes"
                    android:textSize="13sp" android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <LinearLayout android:id="@+id/navFeedback" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavFeedback" android:layout_width="20dp"
                    android:layout_height="20dp" android:src="@drawable/ic_feedback_gray"
                    app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavFeedback" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Feedback"
                    android:textSize="13sp" android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navSettings" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavSettings" android:layout_width="25dp"
                    android:layout_height="25dp" android:src="@drawable/ic_profile_blue"
                    app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavSettings" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Profile"
                    android:textSize="13sp" android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/fabAdd"
            android:layout_width="59dp"
            android:layout_height="59dp"
            android:layout_gravity="top|center_horizontal"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1246C2">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:layout_gravity="center" android:src="@drawable/ic_add_routes" />
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>