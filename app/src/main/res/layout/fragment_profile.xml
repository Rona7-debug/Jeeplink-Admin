<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7F4"
    tools:context=".Home.Profile">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Admin Profile"
            android:fontFamily="@font/lato_bold"
            android:textColor="#0F172A"
            android:gravity="center"
            android:textSize="22sp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#1246C2">

                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="A"
                        android:gravity="center"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#0F172A"
                    android:textSize="20sp"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Administrator"
                    android:fontFamily="@font/lato_regular"
                    android:textColor="#1246C2"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT INFORMATION"
                android:fontFamily="@font/lato_bold"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="8dp" />

            <!-- Account card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E8E8E8"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Username -->
                    <LinearLayout
                        android:id="@+id/rowUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2FF">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_username"
                                app:tint="#1246C2" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Username"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvUsernameValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Admin"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#0F172A"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            app:tint="#CBD5E1" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                    <!-- Email -->
                    <LinearLayout
                        android:id="@+id/rowEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2FF">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_email"
                                app:tint="#1246C2" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Email"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvEmailValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="admin@email.com"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#0F172A"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_lock"
                            app:tint="#CBD5E1" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                    <!-- Password -->
                    <LinearLayout
                        android:id="@+id/rowPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:foreground="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2FF">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_password"
                                app:tint="#1246C2" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Password"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="••••••••••••"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#0F172A"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_back"
                            app:tint="#94A3B8"
                            android:rotation="180" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- APP SETTINGS label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APP SETTINGS"
                android:fontFamily="@font/lato_bold"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="8dp" />

            <!-- Settings card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E8E8E8"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Notifications -->
                    <LinearLayout
                        android:id="@+id/rowNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:foreground="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2FF">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_notif"
                                app:tint="#1246C2" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Notifications"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#0F172A"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Alerts for new feedback"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_back"
                            app:tint="#94A3B8"
                            android:rotation="180" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                    <!-- Export Routes -->
                    <LinearLayout
                        android:id="@+id/rowExportRoutes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:foreground="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <androidx.cardview.widget.CardView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#EEF2FF">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_download"
                                app:tint="#1246C2" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Export Routes"
                                android:fontFamily="@font/lato_bold"
                                android:textColor="#0F172A"
                                android:textSize="15sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Download all routes as CSV"
                                android:fontFamily="@font/lato_regular"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_arrow_back"
                            app:tint="#94A3B8"
                            android:rotation="180" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sign Out -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSignOut"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#FECACA"
                app:cardBackgroundColor="#FFF5F5"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_logout"
                        android:layout_marginEnd="10dp"
                        app:tint="#E03C3C" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign Out"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#E03C3C"
                        android:textSize="16sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- App version -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="JeepLink Admin v1.0.0"
                android:fontFamily="@font/lato_regular"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/navCardView"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bottom_nav_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="20dp"
            android:layout_gravity="bottom">

            <LinearLayout android:id="@+id/navHome" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavHome" android:layout_width="20dp"
                    android:layout_height="20dp" android:src="@drawable/ic_home_blue"
                    app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavHome" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Home"
                    android:textSize="13sp" android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navRoutes" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavRoutes" android:layout_width="20dp"
                    android:layout_height="20dp" android:src="@drawable/ic_routes_gray"
                    app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavRoutes" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Routes"
                    android:textSize="13sp" android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <LinearLayout android:id="@+id/navFeedback" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavFeedback" android:layout_width="20dp"
                    android:layout_height="20dp" android:src="@drawable/ic_feedback_blue"
                    app:tint="#94A3B8" />
                <TextView android:id="@+id/tvNavFeedback" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Feedback"
                    android:textSize="13sp" android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8" android:layout_marginTop="2dp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/navSettings" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center" android:padding="6dp">
                <ImageView android:id="@+id/ivNavSettings" android:layout_width="25dp"
                    android:layout_height="25dp" android:src="@drawable/ic_profile_blue" />
                <TextView android:id="@+id/tvNavSettings" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Profile"
                    android:textSize="13sp" android:fontFamily="@font/lato_bold"
                    android:textColor="#1246C2" android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/fabAdd"
            android:layout_width="59dp"
            android:layout_height="59dp"
            android:layout_gravity="top|center_horizontal"
            app:cardCornerRadius="28dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#1246C2">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:layout_gravity="center" android:src="@drawable/ic_add_routes" />
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>