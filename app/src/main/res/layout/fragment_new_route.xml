<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    tools:context=".Home.NewRoute">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#000000" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="New Route"
            android:fontFamily="@font/lato_bold"
            android:textColor="#000000"
            android:textSize="22sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Save"
            android:fontFamily="@font/lato_regular"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/btn_blue_rounded" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ROUTE CODE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTE CODE"
                android:fontFamily="@font/lato_bold"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <EditText
                    android:id="@+id/etRouteCode"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@null"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:hint="e.g. 04B, 13C, MI-01A"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#0F172A"
                    android:fontFamily="@font/lato_bold"
                    android:textSize="16sp"
                    android:inputType="text"
                    android:singleLine="true" />

            </androidx.cardview.widget.CardView>

            <!-- VEHICLE TYPE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VEHICLE TYPE"
                android:fontFamily="@font/lato_bold"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/vehicleTypeToggle"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:background="@drawable/toggle_bg"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnTraditional"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="5dp"
                    android:text="Traditional"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@drawable/toggle_selected" />

                <TextView
                    android:id="@+id/btnModern"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="5dp"
                    android:text="Modern"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#64748B"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- FARES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NORMAL FARE"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/etNormalFare"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@null"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:enabled="false"
                            android:focusable="false"
                            android:hint="Auto-computed"
                            android:textColorHint="#AAAAAA"
                            android:textColor="#0F172A"
                            android:fontFamily="@font/lato_regular"
                            android:textSize="16sp"
                            android:singleLine="true" />

                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISCOUNTED"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#64748B"
                        android:textSize="14sp"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/etDiscountedFare"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@null"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:enabled="false"
                            android:focusable="false"
                            android:hint="Auto-computed"
                            android:textColorHint="#AAAAAA"
                            android:textColor="#0F172A"
                            android:fontFamily="@font/lato_regular"
                            android:textSize="16sp"
                            android:singleLine="true" />

                    </androidx.cardview.widget.CardView>
                </LinearLayout>

            </LinearLayout>

            <!-- MAJOR STOPS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MAJOR STOPS"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:letterSpacing="0.08" />

                <LinearLayout
                    android:id="@+id/btnAddStop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_add_circle"
                        app:tint="#1246C2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="ADD STOP"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#1246C2"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:id="@+id/majorStopsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp"
                    android:minHeight="60dp" />

            </androidx.cardview.widget.CardView>

            <!-- POINTS ALONG ROUTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="POINTS ALONG THIS ROUTE"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:letterSpacing="0.08" />

                <LinearLayout
                    android:id="@+id/btnAddRoute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_add_circle"
                        app:tint="#1246C2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="ADD POINT"
                        android:fontFamily="@font/lato_bold"
                        android:textColor="#1246C2"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:id="@+id/pointsAlongList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp"
                    android:minHeight="60dp" />

            </androidx.cardview.widget.CardView>

            <!-- ROUTE MAP PREVIEW -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTE MAP PREVIEW"
                android:fontFamily="@font/lato_bold"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvWaypointCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 waypoints dropped"
                    android:fontFamily="@font/lato_regular"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btnImportKml"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="📂 Import KML"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#1246C2"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/btn_outline_blue" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <org.osmdroid.views.MapView
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Fullscreen button bottom-right -->
                    <LinearLayout
                        android:id="@+id/btnFullscreenMap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#CC1246C2"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:layout_margin="10dp"
                        android:elevation="4dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_fullscreen"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Full Screen"
                            android:fontFamily="@font/lato_bold"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp" />

                    </LinearLayout>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- Undo / Clear buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnUndoWaypoint"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="↩ Undo Last"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#1246C2"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="@drawable/btn_outline_blue" />

                <TextView
                    android:id="@+id/btnClearWaypoints"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="✕ Clear All"
                    android:fontFamily="@font/lato_bold"
                    android:textColor="#E03C3C"
                    android:textSize="14sp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>